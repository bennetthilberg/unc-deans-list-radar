{
  "manifest_version": 3,
  "name": "UNC Deans List Radar",
  "version": "0.1.0",
  "description": "Shows Dean's List status on UNC-Chapel Hill Canvas rosters",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "UNC Deans List Radar",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://uncch.instructure.com/courses/*/users*"],
      "css": ["src/styles.css"],
      "js": [
        "src/name-utils.js",
        "src/deans-list-data.js",
        "src/content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
